# ── Node / TypeScript ────────────────────────────────────────────
node_modules/
# dist/ is built locally + by CI for `npm publish`. Plugin distribution is via
# npm (see .claude-plugin/marketplace.json source: npm), so end users get the
# bundled dist/ from the npm registry — main stays clean.
dist/
dist-test/
*.tsbuildinfo
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Web frontend ─────────────────────────────────────────────────
web/node_modules/
web/dist/
web/build/
web/.next/
web/.turbo/
web/.vite/

# ── Environment / secrets ────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Editor / OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-*
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Claude / OMC project state ───────────────────────────────────
.claude/
.omc/sessions/
.omc/state/
.omc/logs/
.omc/
presentation/
research/

# ── Hook payload temp files ──────────────────────────────────────
/tmp/skillogy-*.log
/tmp/skillogy-*.pid

# ── Legacy Python (kept under legacy-python/) ────────────────────
legacy-python/.venv/
legacy-python/.pytest_cache/
legacy-python/__pycache__/
legacy-python/**/__pycache__/
legacy-python/**/*.pyc

# ── Misc ─────────────────────────────────────────────────────────
*.bak
*.tmp
.cache/
