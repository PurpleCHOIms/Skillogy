# Neo4j connection (matches docker-compose.yml defaults)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillrouter

# LLM provider override (optional; default auto-detect)
#   sdk    — Claude Agent SDK (OAuth from Claude Code, no API key needed) [default]
#   gemini — Google Gemini (requires GOOGLE_API_KEY)
#   api    — Anthropic API (requires ANTHROPIC_API_KEY)
SKILLOGY_LLM=sdk

# Optional API keys (only needed when not using sdk path)
#GOOGLE_API_KEY=...
#ANTHROPIC_API_KEY=...
#SKILLOGY_GEMINI_MODEL=gemini-pro-latest

# Routing knobs
SKILLOGY_MIN_SCORE=0.4
SKILLOGY_RELATES_K=3
#SKILLOGY_DISABLE=1   # bypass the hook entirely (passthrough)

# Extra skill discovery roots (colon-separated absolute paths)
#SKILLOGY_EXTRA_ROOTS=/path/to/extra/skills:/another/path

# Web API port (used by `skillogy serve` and SessionStart bootstrap)
SKILLOGY_WEB_PORT=8765
