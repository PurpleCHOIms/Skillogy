# Skill Trigger Graph — environment variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; .env.example is committed as the template.

# ── LLM provider ──────────────────────────────────────────────────
# Default: claude-agent-sdk (uses Claude Code OAuth — no API key needed).
# Override with SKILLOGY_LLM if you want to use API keys instead:
#   SKILLOGY_LLM=gemini   → requires GOOGLE_API_KEY
#   SKILLOGY_LLM=api      → requires ANTHROPIC_API_KEY
#   SKILLOGY_LLM=sdk      → claude-agent-sdk (default)

# Optional: only set these if you opt out of SDK
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Override the default Gemini model (only used when SKILLOGY_LLM=gemini)
# SKILLOGY_GEMINI_MODEL=gemini-pro-latest

# ── Graph backend ────────────────────────────────────────────────
# Default: "kuzu" — embedded, single .db directory at SKILLOGY_KUZU_PATH.
# Set to "neo4j" to use a server-based Neo4j instance (requires NEO4J_* below).
# SKILLOGY_DB=kuzu
# SKILLOGY_KUZU_PATH=~/.skillogy/graph.kuzu

# ── Neo4j (only when SKILLOGY_DB=neo4j) ──────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillrouter

# ── Hook tuning ──────────────────────────────────────────────────
# Disable the Claude Code hook entirely (1 = disabled)
# SKILLOGY_DISABLE=
# Minimum router score below which the hook emits passthrough
# SKILLOGY_MIN_SCORE=1.0
