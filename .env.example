# Skill Trigger Graph — environment variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; .env.example is committed as the template.

# ── LLM provider ──────────────────────────────────────────────────
# Priority: GOOGLE_API_KEY > claude-agent-sdk (auto if Claude Code logged in) > ANTHROPIC_API_KEY
# Override explicit provider with: SKILL_ROUTER_LLM=gemini|sdk|api

# Google Gemini (preferred for indexing — free tier, fast)
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Anthropic Claude API key (fallback, or for Anthropic-direct mode)
ANTHROPIC_API_KEY=

# Force a specific provider regardless of which keys are set
# SKILL_ROUTER_LLM=gemini

# Override the default Gemini model (default: gemini-pro-latest as of 2026-04-26)
# Aliases (auto-tracked): gemini-pro-latest, gemini-flash-latest, gemini-flash-lite-latest
# Explicit pins:          gemini-3.1-pro-preview, gemini-3.1-flash-lite-preview
# SKILL_ROUTER_GEMINI_MODEL=gemini-pro-latest

# ── Neo4j ────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillrouter

# ── Hook tuning ──────────────────────────────────────────────────
# Disable the Claude Code hook entirely (1 = disabled)
# SKILL_ROUTER_DISABLE=
# Minimum router score below which the hook emits passthrough
# SKILL_ROUTER_MIN_SCORE=1.0
